# QuantWeave 环境变量配置（复制为 .env 使用）

# Tushare Token（https://tushare.pro 注册获取）
TUSHARE_TOKEN=

# 数据库（默认 SQLite，可改为 MySQL/PostgreSQL）
DATABASE_URL=sqlite:///./quantweave.db

# 风控参数
MAX_POSITION_RATIO=0.3
MAX_LOSS_RATIO=0.05
STOP_LOSS_RATIO=0.08
TAKE_PROFIT_RATIO=0.15

# 通知配置（按需填写）
DINGTALK_WEBHOOK=
WECHAT_WEBHOOK=
EMAIL_SMTP=
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECEIVER=

# 调试模式
DEBUG=True
